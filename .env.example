# ORA NFS-e Automático — ambiente local / Render
# Não envie este arquivo preenchido para o GitHub. Use .env somente localmente.
# No Render, configure essas variáveis em Environment ou via render.yaml.

APP_NAME=ORA NFS-e Automático
APP_VERSION=0.14.0
APP_ENV=local

# Segurança
# Para URL pública, use REQUIRE_AUTH=true e defina APP_ACCESS_PASSWORD.
REQUIRE_AUTH=false
APP_ACCESS_PASSWORD=
APP_SESSION_SECRET=
SESSION_MAX_AGE_SECONDS=43200
SECURE_COOKIES=false

# Persistência
# Local: ./data
# Render com Disk: /opt/render/project/src/data
DATA_DIR=./data

# API ADN/NFS-e Nacional
# Produção:          https://adn.nfse.gov.br/contribuintes
# Produção restrita: https://adn.producaorestrita.nfse.gov.br/contribuintes
NFSE_ADN_BASE_URL=https://adn.nfse.gov.br/contribuintes
REQUEST_TIMEOUT_SECONDS=60

# Controle de ritmo para reduzir ocorrência de HTTP 429 / Too Many Requests
REQUEST_DELAY_SECONDS=0.4
RATE_LIMIT_PAUSE_SECONDS=45
RATE_LIMIT_MAX_PAUSE_SECONDS=300
MAX_RATE_LIMIT_RETRIES=3

DEFAULT_MAX_CONSULTAS=500
DEFAULT_STOP_AFTER_EMPTY=3

# CORS: normalmente não precisa configurar no Render porque interface e API rodam no mesmo domínio.
ALLOWED_ORIGINS=http://127.0.0.1:8000,http://localhost:8000
